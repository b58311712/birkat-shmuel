# =============================================================================
# מטבח החסד — .gitignore (שורש)
# מעלים ל-git רק קוד. סודות, תלויות, ונתונים אישיים — לא!
# =============================================================================

# --- תלויות ---
node_modules/
**/node_modules/

# --- משתני סביבה / סודות (service_role key, JWT_SECRET) ---
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# --- לוגים ותוצרי build ---
*.log
dist/
**/dist/
.vite/

# --- קבצים אישיים / נתוני לקוחות אמיתיים (אסור ל-GitHub) ---
# רשימות אנשי קשר, אקסלים, ומסמכי מקור
*.csv
*.xlsx
*.xls
*.pdf
*.png
*.jpg
*.jpeg
# חריג: לוגו האפליקציה — נכס סטטי שחייב להיכנס ל-build ולדיפלוי (לא נתוני לקוחות)
!client/public/logo.png

# --- מסמכי עבודה פנימיים (אופציונלי — מוחרגים ליתר ביטחון) ---
מתכונים*
תפריט*
עותק*
קלויז*
*תפריט שבת חסד*

# --- מערכת הפעלה / עורך ---
.DS_Store
Thumbs.db
.vscode/
.idea/
.agents/
