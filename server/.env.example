# =============================================================================
# מטבח החסד - שרת: משתני סביבה
# =============================================================================
# העתיקי קובץ זה ל-.env ומלאי את הערכים מ-Supabase Dashboard:
#   Settings > API
# =============================================================================

# כתובת הפרויקט (Project URL) - לא סודי
SUPABASE_URL=https://alkafqsetdjccyrlzutz.supabase.co

# מפתח service_role - ⚠️ סודי! עוקף RLS. אסור לחשוף/להעלות ל-git.
# נמצא ב: Settings > API > Project API keys > service_role  (secret)
SUPABASE_SERVICE_ROLE_KEY=

# פורט השרת
PORT=3005

# כתובת הפרונט (ל-CORS) - בפיתוח זה vite
CLIENT_ORIGIN=http://localhost:5173

# סוד לחתימת טוקני התחברות מנהל (JWT) - ⚠️ סודי!
# מחרוזת אקראית ארוכה. אפשר לייצר:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# תוקף טוקן מנהל (אופציונלי; ברירת מחדל 12h)
JWT_TTL=12h

# =============================================================================
# שליחת מיילים (SMTP) - סעיף 18
# =============================================================================
# ⚠️ אם SMTP_HOST ריק/חסר - המערכת ב"מצב יבש": מיילים מתועדים ב-email_log
# עם status='dry_run' ולא נשלחים בפועל. כך אפשר לבדוק את כל הזרימה בלי חשבון.
# למעבר לשליחה אמיתית - מלאי את הפרטים והפעילי מחדש את השרת (env נטען בהפעלה).
#
# דוגמה ל-Gmail (דורש "סיסמת אפליקציה" - App Password, לא סיסמת החשבון הרגילה):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your@gmail.com
#   SMTP_PASS=<App Password בן 16 תווים>
#   SMTP_FROM=מטבח החסד <your@gmail.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
